# Google Search Console verification
# Obtenez la valeur sur https://search.google.com/search-console
# Laisser vide ou ne pas définir pour désactiver la balise
GOOGLE_VERIFICATION=

# ─── Administration (/admin) ──────────────────────────────────────────────────
# Email et mot de passe pour se connecter à l'interface d'administration
ADMIN_EMAIL=admin@amc-savoie.fr
ADMIN_PASSWORD=changeme

# Clé secrète pour signer les tokens de session (HMAC-SHA256)
# Générer une valeur aléatoire forte, ex: openssl rand -base64 32
ADMIN_SECRET=changeme-generate-a-strong-random-secret-here
